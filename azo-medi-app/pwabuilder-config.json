{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/pwabuilder/main/packages/cli/schema/pwa-builder-config.schema.json",
  "schema_version": "1",
  "name": "Azo Medi",
  "short_name": "Azo Medi",
  "url": "",
  "start_url": "/index.html",
  "display": "standalone",
  "background_color": "#1A2732",
  "theme_color": "#1A2732",
  "orientation": "portrait",
  "description": "Tu tienda de suplementos con opcion de pago a plazos. Compra ahora y paga en cuotas sin interes.",
  "categories": ["shopping", "finance"],
  "icons": [
    {
      "src": "icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "androidPackageId": "com.azomedi.app",
  "androidVersionCode": 1,
  "androidMinVersion": 21,
  "androidTargetSdk": 33,
  "permissions": ["geolocation"],
  "features": [
    {
      "name": "android.hardware.location",
      "required": true
    },
    {
      "name": "android.hardware.location.gps",
      "required": true
    },
    {
      "name": "android.hardware.location.network",
      "required": true
    }
  ]
}
